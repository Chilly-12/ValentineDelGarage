<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.ValentinesGarage" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor" tools:targetApi="l">@color/garage_dark</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
    </style>

    <!-- Compose paints the splash itself, but we still want the system
         window to match so the user never sees a white flash. -->
    <style name="Theme.ValentinesGarage.Splash" parent="Theme.ValentinesGarage">
        <item name="android:windowBackground">@color/garage_dark</item>
        <item name="android:statusBarColor" tools:targetApi="l">@color/garage_dark</item>
        <item name="android:navigationBarColor" tools:targetApi="l">@color/garage_dark</item>
    </style>
</resources>
